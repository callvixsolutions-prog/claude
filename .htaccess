# ==========================================================================
# Callvix Solutions — Apache / LiteSpeed config (Hostinger)
# Handles: HTTPS, 301 redirects from the old WordPress URLs, clean URLs,
# compression, browser caching, and security headers.
# ==========================================================================

Options -Indexes
DirectoryIndex index.html

# --------------------------------------------------------------------------
# 1. HTTPS + canonical host (non-www)
# --------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Force non-www (change to the www block below if you prefer www)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # ------------------------------------------------------------------------
  # 2. 301 REDIRECTS — old WordPress URLs -> new pages
  #    These preserve the Google rankings the old site already earned.
  # ------------------------------------------------------------------------
  RewriteRule ^about-us/?$            /about.html      [R=301,L]
  RewriteRule ^why-egypt/?$           /about.html      [R=301,L]
  RewriteRule ^landing/?$             /services.html   [R=301,L]
  RewriteRule ^pricing/?$             /pricing.html    [R=301,L]
  RewriteRule ^contact-us/?$          /contact.html    [R=301,L]
  RewriteRule ^home/?$                /                [R=301,L]

  # Old WordPress sitemaps -> new sitemap
  RewriteRule ^sitemap_index\.xml$    /sitemap.xml     [R=301,L]
  RewriteRule ^page-sitemap\.xml$     /sitemap.xml     [R=301,L]
  RewriteRule ^wp-sitemap\.xml$       /sitemap.xml     [R=301,L]

  # Retire leftover WordPress paths so they don't 500 or leak
  RewriteRule ^wp-admin(/.*)?$        /                [R=301,L]
  RewriteRule ^wp-login\.php$         /                [R=301,L]

  # ------------------------------------------------------------------------
  # 3. Clean URLs — /pricing also works, serving /pricing.html
  # ------------------------------------------------------------------------
  # Strip .html from the address bar
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Internally map extensionless requests to the .html file
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# --------------------------------------------------------------------------
# 4. Custom error page
# --------------------------------------------------------------------------
ErrorDocument 404 /404.html

# --------------------------------------------------------------------------
# 5. Compression (smaller = faster = better Core Web Vitals / SEO)
# --------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --------------------------------------------------------------------------
# 6. Browser caching
# --------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                 "access plus 1 hour"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType text/xml                  "access plus 1 day"
</IfModule>

# --------------------------------------------------------------------------
# 7. Security headers
# --------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# --------------------------------------------------------------------------
# 8. Correct MIME types
# --------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType application/xml .xml
  AddType text/plain .txt
</IfModule>
